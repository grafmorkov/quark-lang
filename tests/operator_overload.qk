struct Pair { x: i32; y: i32; };

func operator &(p1: Pair, p2: Pair) Pair {
    @init mut r: Pair;
    r.x = p1.x & p2.x;
    r.y = p1.y & p2.y;
    return r;
}

func operator |(p1: Pair, p2: Pair) Pair {
    @init mut r: Pair;
    r.x = p1.x | p2.x;
    r.y = p1.y | p2.y;
    return r;
}

@entry func main() i32 {
    @init mut a: i32;
    @init mut b: i32;
    @init mut res: i32;

    // bitwise AND
    a = 6; b = 3;
    res = a & b;
    if (res != 2) { return 1; }

    // bitwise OR
    res = a | b;
    if (res != 7) { return 2; }

    // logical AND
    a = 6; b = 3;
    res = a && b;
    if (res != 1) { return 3; }

    // logical AND with zero
    @init mut z: i32;
    z = 0;
    res = a && z;
    if (res != 0) { return 4; }

    // logical OR (one non-zero)
    res = z || b;
    if (res != 1) { return 5; }

    // logical OR (both zero)
    @init mut z2: i32;
    z2 = 0;
    res = z || z2;
    if (res != 0) { return 6; }

    // &= compound assignment
    a = 6; b = 3;
    a &= b;
    if (a != 2) { return 7; }

    // |= compound assignment
    a = 6; b = 3;
    a |= b;
    if (a != 7) { return 8; }

    // & vs | precedence
    res = 6 & 3 | 1;   // (6 & 3) | 1 = 2 | 1 = 3
    if (res != 3) { return 9; }

    //&& vs || precedence
    @init mut t: i32;
    t = 1;
    @init mut f: i32;
    f = 0;
    res = t && f || t;  // (t && f) || t = 0 || 1 = 1
    if (res != 1) { return 10; }

    // | vs && precedence
    res = 1 | 0 && 0;   // (1 | 0) && 0 = 1 && 0 = 0
    if (res != 0) { return 11; }

    // & vs == precedence
    @init mut cmp: i32;
    cmp = 6;
    res = cmp == 6 & 1;  // (cmp == 6) & 1 = 1 & 1 = 1
    if (res != 1) { return 12; }

    // struct operator&
    @init mut p1: Pair;
    p1.x = 6; p1.y = 12;
    @init mut p2: Pair;
    p2.x = 3; p2.y = 7;
    @init mut pr: Pair;
    pr = p1 & p2;
    if (pr.x != (6 & 3)) { return 13; }
    if (pr.y != (12 & 7)) { return 14; }

    // struct operator|
    pr = p1 | p2;
    if (pr.x != (6 | 3)) { return 15; }
    if (pr.y != (12 | 7)) { return 16; }

    // all good
    return 0;
}
