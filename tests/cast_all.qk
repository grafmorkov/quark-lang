func main() i32 {
    // int -> int widening (signed)
    a: i8 = 42 as i8;
    b: i16 = a as i16;
    c: i32 = b as i32;
    d: i64 = c as i64;

    // int -> int widening (unsigned)
    e: u8 = 42 as u8;
    f: u16 = e as u16;
    g: u32 = f as u32;
    h: u64 = g as u64;

    // int -> int narrowing
    i: i64 = 1000 as i64;
    j: i32 = i as i32;
    k: i16 = j as i16;
    l: i8 = k as i8;

    // same-size signedness change
    m: i32 = 100 as i32;
    n: u32 = m as u32;

    // bitcast same size
    o: i64 = 500 as i64;
    p: u64 = o as! u64;

    // string casts
    q: str = 42 as str;
    r: str = 0 as str;
    s: str = 255 as u32 as str;
    t: str = 1000 as i64 as str;

    return 0 as i32;
}
